# Copy this file to .env and fill in values for local development.

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://phantom:phantom@localhost:5432/faceless_spectre

# Redis (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# Colyseus / Fastify server port
PORT=2567

NODE_ENV=development

# Next.js client — public server URL (used by browser)
NEXT_PUBLIC_SERVER_URL=http://localhost:2567
