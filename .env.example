# Copy this file to .env and fill in values for local development.

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://phantom:phantom@localhost:5433/faceless_spectre

# Redis (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# Colyseus / Fastify server port
PORT=2567

NODE_ENV=development

# Next.js client — public server URL (used by browser)
NEXT_PUBLIC_SERVER_URL=http://localhost:2567

# ── Production (set as Fly.io secrets and Cloudflare Pages env vars) ──────────
# DATABASE_URL=postgresql://...   fly postgres attach sets this automatically
# REDIS_URL=rediss://...          fly ext redis create sets this automatically
# NEXT_PUBLIC_SERVER_URL=https://faceless-spectre.fly.dev  (CF Pages env var)
